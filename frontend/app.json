{
  "expo": {
    "name": "Barkodcu Cepte",
    "slug": "barkodcu-cepte",
    "version": "1.0.26",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "barkodcucepte",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cakmakebubekir.barkodcucepte",
      "buildNumber": "30",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "CFBundleDisplayName": "Barkodcu",
        "NSCameraUsageDescription": "Barkod tarama için kamera kullanılır",
        "NSPhotoLibraryUsageDescription": "Raporları kaydetmek için galeri erişimi gerekli",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.cakmakebubekir.barkodcucepte",
      "versionCode": 30,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Barkod tarama için kamera izni gerekli"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#2563EB"
        }
      ],
      "expo-web-browser",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "10479f35-915a-47fa-9f2e-947055337764"
      }
    }
  }
}
