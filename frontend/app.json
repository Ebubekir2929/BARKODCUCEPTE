{
  "expo": {
    "name": "Barkodcu Cepte",
    "slug": "barkodcu-cepte",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "barkodcucepte",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.berkyazilim.barkodcucepte",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Barkod tarama için kamera kullanılır",
        "NSPhotoLibraryUsageDescription": "Raporları kaydetmek için galeri erişimi gerekli"
      }
    },
    "android": {
      "package": "com.berkyazilim.barkodcucepte",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2563EB"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Barkod tarama için kamera izni gerekli"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#2563EB"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "10479f35-915a-47fa-9f2e-947055337764"
      }
    }
  }
}
